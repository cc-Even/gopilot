OPENAI_API_KEY=your_api_key_here
MODEL=gpt-4o-mini
# Optional: OpenAI-compatible base URL
OPENAI_BASE_URL=https://api.openai.com/v1
# Optional: wait N seconds and retry when the API returns HTTP 429
OPENAI_RATE_LIMIT_RETRY_SECONDS=1
# Optional: max tool/model turns for one agent run
AGENT_MAX_TURNS=999
# Optional: trigger auto-compaction when marshaled conversation chars exceed this threshold
AUTO_COMPACT_TRIGGER_CHARS=100000
# Optional: max completion tokens used to summarize compacted context
AUTO_COMPACT_SUMMARY_MAX_TOKENS=20000
