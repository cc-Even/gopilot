OPENAI_API_KEY=your_api_key_here
MODEL=gpt-4o-mini
# Optional: choose provider explicitly (openai or gemini). If omitted, gemini* models auto-select Gemini.
LLM_PROVIDER=openai
# Optional: choose Gemini backend explicitly (developer or vertex). If omitted, gopilot auto-detects.
GEMINI_BACKEND=developer
# Optional: Gemini Developer API key
GEMINI_API_KEY=your_gemini_api_key
# Optional: Gemini Developer API base URL
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
# Optional: OpenAI-compatible base URL
OPENAI_BASE_URL=https://api.openai.com/v1
# Optional: Vertex AI Gemini settings. If no access token is set, ADC/default credentials are used.
VERTEX_AI_ACCESS_TOKEN=your_google_oauth_access_token
VERTEX_AI_PROJECT_ID=your-gcp-project-id
VERTEX_AI_LOCATION=global
VERTEX_AI_BASE_URL=https://aiplatform.googleapis.com
# Optional: wait N seconds and retry when the API returns HTTP 429
OPENAI_RATE_LIMIT_RETRY_SECONDS=1
# Optional: max tool/model turns for one agent run
AGENT_MAX_TURNS=999
# Optional: trigger auto-compaction when marshaled conversation chars exceed this threshold
AUTO_COMPACT_TRIGGER_CHARS=100000
# Optional: max completion tokens used to summarize compacted context
AUTO_COMPACT_SUMMARY_MAX_TOKENS=20000
